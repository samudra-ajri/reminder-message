generator client {
  provider = "prisma-client-js"
}

// Ensure the user adjusts DATABASE_URL locally as needed
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String   @unique // Adding unique email attribute
  birthday  DateTime @db.Date // Storing just the date part for exact match
  location  String   // Storing IANA Timezone, e.g., 'America/New_York'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relationship for idempotency checks
  outboxMessages OutboxMessage[]
}

model OutboxMessage {
  id        Int      @id @default(autoincrement())
  userId    Int
  eventYear Int      // The year the message was sent (e.g., 2026)
  eventType String   // e.g., 'BIRTHDAY', 'ANNIVERSARY'
  status    String   // 'PENDING', 'SENT', 'FAILED'
  sentAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Unique constraint to ensure idempotency so a person won't get two birthday messages in the same year
  @@unique([userId, eventYear, eventType])
}
